#include <stdio.h>
#include <stdlib.h>
#include <time.h>

#define N 10
#define MAX 5000

void sort(int a[], int n)
{
    for(int i=0;i<n-1;i++)
        for(int j=i+1;j<n;j++)
            if(a[i] > a[j])
            {
                int t=a[i];
                a[i]=a[j];
                a[j]=t;
            }
}

void FIFO(int req[], int head)
{
    int total=0;

    printf("\nFIFO Order:\n%d", head);

    for(int i=0;i<N;i++)
    {
        total += abs(head - req[i]);
        head = req[i];
        printf(" -> %d", head);
    }

    printf("\nTotal Head Movement = %d\n", total);
}

void SSTF(int req[], int head)
{
    int visited[N]={0};
    int total=0;

    printf("\nSSTF Order:\n%d", head);

    for(int i=0;i<N;i++)
    {
        int min=10000, index=-1;

        for(int j=0;j<N;j++)
        {
            if(!visited[j])
            {
                int dist=abs(head-req[j]);
                if(dist<min)
                {
                    min=dist;
                    index=j;
                }
            }
        }

        visited[index]=1;
        total+=abs(head-req[index]);
        head=req[index];

        printf(" -> %d", head);
    }

    printf("\nTotal Head Movement = %d\n", total);
}

void LOOK(int req[], int head)
{
    int a[N];
    int total=0;

    for(int i=0;i<N;i++) a[i]=req[i];

    sort(a,N);

    printf("\nLOOK Order:\n%d", head);

    int pos=0;
    while(pos<N && a[pos]<head) pos++;

    for(int i=pos;i<N;i++)
    {
        total+=abs(head-a[i]);
        head=a[i];
        printf(" -> %d", head);
    }

    for(int i=pos-1;i>=0;i--)
    {
        total+=abs(head-a[i]);
        head=a[i];
        printf(" -> %d", head);
    }

    printf("\nTotal Head Movement = %d\n", total);
}

void CSCAN(int req[], int head)
{
    int a[N];
    int total=0;

    for(int i=0;i<N;i++) a[i]=req[i];

    sort(a,N);

    printf("\nCSCAN Order:\n%d", head);

    int pos=0;
    while(pos<N && a[pos]<head) pos++;

    for(int i=pos;i<N;i++)
    {
        total+=abs(head-a[i]);
        head=a[i];
        printf(" -> %d", head);
    }

    total += abs(head - (MAX-1));
    head = 0;

    printf(" -> %d -> %d", MAX-1, head);

    total += MAX-1;

    for(int i=0;i<pos;i++)
    {
        total+=abs(head-a[i]);
        head=a[i];
        printf(" -> %d", head);
    }

    printf("\nTotal Head Movement = %d\n", total);
}

int main(int argc, char *argv[])
{
    if(argc!=2)
    {
        printf("Usage: %s <initial_head>\n",argv[0]);
        return 1;
    }

    int head=atoi(argv[1]);
    int req[N];

    srand(time(NULL));

    printf("Requests:\n");

    for(int i=0;i<N;i++)
    {
        req[i]=rand()%MAX;
        printf("%d ",req[i]);
    }

    printf("\nInitial Head = %d\n",head);

    FIFO(req,head);
    SSTF(req,head);
    LOOK(req,head);
    CSCAN(req,head);

    return 0;
}
